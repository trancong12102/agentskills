{
  "mcpServers": {
    "fff": {
      "type": "stdio",
      "command": "fff-mcp",
      "args": [],
      "env": {}
    },
    "sourcegraph": {
      "type": "http",
      "url": "https://sourcegraph.com/.api/mcp",
      "headers": {
        "Authorization": "token ${SOURCEGRAPH_TOKEN}"
      }
    },
    "morph": {
      "type": "stdio",
      "command": "bunx",
      "args": ["@morphllm/morphmcp@latest"],
      "env": {
        "MORPH_API_KEY": "${MORPH_API_KEY}",
        "DISABLED_TOOLS": "edit_file"
      }
    }
  }
}
